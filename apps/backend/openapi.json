{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "SnapCos API",
    "description": "API documentation for the SnapCos backend"
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "email",
          "role"
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthTokenResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserSummary"
          },
          "token": {
            "type": "string"
          }
        },
        "required": [
          "user",
          "token"
        ]
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "role"
        ]
      },
      "CostumeImage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "costumeId": {
            "type": "number"
          },
          "imageUrl": {
            "type": "string"
          },
          "isPrimary": {
            "type": "boolean"
          }
        },
        "required": [
          "costumeId",
          "imageUrl",
          "isPrimary"
        ]
      },
      "Costume": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "vendorId": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "dailyRate": {
            "type": "number"
          },
          "weeklyRate": {
            "type": "number",
            "nullable": true
          },
          "monthlyRate": {
            "type": "number",
            "nullable": true
          },
          "securityDeposit": {
            "type": "number"
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "theme": {
            "type": "string",
            "nullable": true
          },
          "size": {
            "type": "string",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "maintenance",
              "retired"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "CostumeImages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CostumeImage"
            }
          }
        },
        "required": [
          "vendorId",
          "name",
          "dailyRate",
          "securityDeposit",
          "status"
        ]
      },
      "CostumeListQuery": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "sort": {
            "type": "string"
          },
          "page": {
            "type": "string"
          },
          "pageSize": {
            "type": "string"
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register a new user",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login to an existing account",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/costumes": {
      "get": {
        "tags": [
          "Costumes"
        ],
        "summary": "Get all costumes",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "q",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "category",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "size",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "gender",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "theme",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "sort",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "pageSize",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of costumes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Costume"
                      }
                    },
                    "total": {
                      "type": "number"
                    },
                    "page": {
                      "type": "number"
                    },
                    "pageSize": {
                      "type": "number"
                    },
                    "totalPages": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "items",
                    "total",
                    "page",
                    "pageSize",
                    "totalPages"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/costumes/{id}": {
      "get": {
        "tags": [
          "Costumes"
        ],
        "summary": "Get costume details by ID",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Costume details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "costume": {
                      "$ref": "#/components/schemas/Costume"
                    },
                    "ratingCount": {
                      "type": "number"
                    },
                    "avgRating": {
                      "type": "number",
                      "nullable": true
                    }
                  },
                  "required": [
                    "costume",
                    "ratingCount",
                    "avgRating"
                  ]
                }
              }
            }
          }
        }
      }
    },
