# Public API base URL for the SnapCos backend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Browser Google key for Places Autocomplete (address search).
# Enable Places API (and Maps JavaScript API for the Places library loader).
# Restrict this key to HTTP referrers (localhost + your production domains).
# Prefer a separate key from the backend GOOGLE_MAPS_API_KEY (Geocoding API only).
# No interactive map is rendered — autocomplete only — to avoid map-load billing.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
