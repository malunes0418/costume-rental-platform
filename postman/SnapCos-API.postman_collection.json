{
  "info": {
    "_postman_id": "a1b2c3d4-snapcos-api",
    "name": "SnapCos API",
    "description": "Backend API for costume-rental-platform.\n\n**Setup:** Import this collection and the **SnapCos \u2014 Local** environment, select that environment, then run **Register** or **Login** \u2014 the response `token` is saved to the environment for Bearer auth on other requests.\n\nNote: `authMiddleware` is global (except `/api/auth/*`), so most routes require a valid JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "(function () {",
                  "  if (![200, 201].includes(pm.response.code)) return;",
                  "  var json;",
                  "  try { json = pm.response.json(); } catch (e) { return; }",
                  "  if (!json || typeof json !== 'object') return;",
                  "  if (json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    pm.collectionVariables.set('token', json.token);",
                  "  }",
                  "  if (json.user && json.user.id != null) {",
                  "    pm.environment.set('userId', String(json.user.id));",
                  "  }",
                  "})();"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"name\": \"{{testName}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Creates a user. On success, saves `token` and `userId` to the active environment."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "(function () {",
                  "  if (![200, 201].includes(pm.response.code)) return;",
                  "  var json;",
                  "  try { json = pm.response.json(); } catch (e) { return; }",
                  "  if (!json || typeof json !== 'object') return;",
                  "  if (json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    pm.collectionVariables.set('token', json.token);",
                  "  }",
                  "  if (json.user && json.user.id != null) {",
                  "    pm.environment.set('userId', String(json.user.id));",
                  "  }",
                  "})();"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "On success, saves `token` and `userId` to the active environment."
          }
        }
      ]
    },
    {
      "name": "API (requires token)",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
